# 基础配置 - 镜像源
registry=https://registry.npmjs.com
# 国内加速（可选，二选一）
# registry=https://registry.npmmirror.com

# 依赖版本控制
save-exact=true                             # 安装依赖时，保存确切版本号（不使用 ^ 或 ~）
save-prefix=""                              # 安装依赖时，不添加任何版本前缀

# 依赖提升策略
hoist=true                                  # 启用依赖提升，减少重复安装
hoist-workspace-packages=true               # 允许提升工作区内的包
shamefully-hoist=false                      # 禁止扁平化提升（避免幽灵依赖）

# 依赖解析策略
strict-peer-dependencies=false              # 允许安装不满足 peer 依赖的包（谨慎使用）
auto-install-peers=true                     # 自动安装缺失的 peer 依赖
resolve-peers-form-workspace=true           # 优先从工作区解析 peer 依赖

# 链接策略
link-workspace-packages=true                # 启用工作区包的符号链接
prefer-workspace-packages=true              # 优先使用工作区内的包版本
shared-workspace-lockfile=true              # 工作区共享锁文件，确保一致的依赖版本

# 性能优化
symlink=true                                # 使用符号链接安装依赖，节省磁盘空间
node-linker=isolated                        # 使用独立的 node_modules 结构，避免依赖冲突

# 缓存配置
cache-dir=node_modules/.cache/pnpm          # 自定义缓存目录
state-dir=node_modules/.pnpm-state          # 自定义状态目录

# 网络配置
network-concurrency=16                      # 限制网络请求的并发数，避免过载
fetch-retries=3                             # 请求失败时的重试次数
fetch-timeout=60000                         # 请求超时时间（毫秒）

# 日志配置
loglevel=warn                               # 设置日志级别（silent, error, warn, info, verbose, silly）
