{
  "extends": "../../tsconfig.json", // 继承根目录TS配置，保持一致的编译选项和路径映射
  "compilerOptions": {
    "outDir": "./dist", // 后续打包输出目录（保持与根目录一致，方便构建工具识别）
    "declaration": true // 生成类型声明文件（.d.ts），关键：供其他包识别类型，尤其在 monorepo 内部依赖时非常重要
  },
  "include": ["./**/*"], // 包含当前包下所有文件（TS/JS/Vue等），确保类型检查覆盖整个包的源码
  "exclude": ["node_modules", "dist"] // 排除依赖和构建产物，避免不必要的类型检查和编译输出
}