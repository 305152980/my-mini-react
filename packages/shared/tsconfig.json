{
  "extends": "../../tsconfig.json", // 继承根目录TS配置
  "compilerOptions": {
    "outDir": "./dist", // 后续打包输出目录（保持与根目录一致，方便构建工具识别）
    "declaration": true, // 生成类型声明文件（.d.ts），关键：供其他包识别类型，尤其在 monorepo 内部依赖时非常重要
    "baseUrl": ".", // 解析非相对模块的基础路径，保持与根目录一致，适配 monorepo 内部结构
    "paths": {}
  },
  "include": ["./**/*"], // 包含当前包下所有文件（TS/JS/Vue等）
  "exclude": ["node_modules", "dist"] // 排除依赖和构建产物
}
